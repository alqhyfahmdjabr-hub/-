{
  "expo": {
    "name": "مجوهرات بابل",
    "slug": "babel-jewelry",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "babeljewelry",
    "platforms": ["ios", "android"],
    "splash": {
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.babel.jewelry"
    },
    "android": {
      "package": "com.babel.jewelry",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "يحتاج التطبيق للوصول إلى الصور لإضافتها للرسائل"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
